<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lt_contact_request_form" model="ir.ui.view">
        <field name="name">lt.contact.request.form</field>
        <field name="model">lt.contact.request</field>
        <field name="arch" type="xml">
            <form string="Contact Request">
                <header>
                    <button name="action_close" string="Close" type="object"
                            class="btn-secondary" invisible="state == 'closed'"/>
                    <button name="action_reopen" string="Reopen" type="object"
                            invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="student_id"/>
                        <field name="teacher_id"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_lt_contact_request_list" model="ir.ui.view">
        <field name="name">lt.contact.request.list</field>
        <field name="model">lt.contact.request</field>
        <field name="arch" type="xml">
            <list string="Contact Requests">
                <field name="name"/>
                <field name="student_id"/>
                <field name="teacher_id"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="action_lt_contact_request" model="ir.actions.act_window">
        <field name="name">Contact Requests</field>
        <field name="res_model">lt.contact.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
