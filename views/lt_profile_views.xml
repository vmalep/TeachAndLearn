<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lt_profile_form" model="ir.ui.view">
        <field name="name">lt.profile.form</field>
        <field name="model">lt.profile</field>
        <field name="arch" type="xml">
            <form string="Profile">
                <header>
                    <button name="action_validate" string="Validate" type="object"
                            class="btn-primary"
                            invisible="not is_teacher or teacher_state == 'validated'"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="not is_teacher or teacher_state != 'validated'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="not is_teacher or teacher_state == 'draft'"/>
                    <field name="teacher_state" widget="statusbar"
                           invisible="not is_teacher"/>
                </header>
                <sheet>
                    <field name="partner_id" widget="many2one_avatar" readonly="1" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <field name="user_id" readonly="1"/>
                    </div>
                    <group>
                        <group string="Role">
                            <field name="is_teacher"/>
                            <field name="is_student"/>
                        </group>
                        <group string="General">
                            <field name="municipality"/>
                            <field name="address"/>
                        </group>
                    </group>
                    <field name="bio" placeholder="About me..."/>
                    <notebook>
                        <page string="Teacher" invisible="not is_teacher">
                            <group>
                                <group>
                                    <field name="native_language_id"/>
                                    <field name="teacher_languages" widget="many2many_tags"/>
                                    <field name="price_per_hour"/>
                                    <field name="currency_id"/>
                                </group>
                                <group>
                                    <field name="availability"/>
                                </group>
                            </group>
                            <separator string="Certificates"/>
                            <field name="certificate_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="issuing_organization"/>
                                    <field name="date_obtained"/>
                                    <field name="date_expiry"/>
                                    <field name="description"/>
                                    <field name="attachment_ids" widget="many2many_binary"/>
                                </list>
                            </field>
                            <separator string="Reviews"/>
                            <group>
                                <field name="rating"/>
                                <field name="review_count"/>
                            </group>
                            <field name="review_ids">
                                <list>
                                    <field name="student_id"/>
                                    <field name="rating"/>
                                    <field name="comment"/>
                                    <field name="date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Student" invisible="not is_student">
                            <group>
                                <field name="student_languages" widget="many2many_tags"/>
                                <field name="student_level"/>
                                <field name="learning_goals"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_lt_profile_list" model="ir.ui.view">
        <field name="name">lt.profile.list</field>
        <field name="model">lt.profile</field>
        <field name="arch" type="xml">
            <list string="Profiles" decoration-warning="is_teacher and teacher_state == 'draft'"
                  decoration-danger="is_teacher and teacher_state == 'rejected'">
                <field name="name"/>
                <field name="is_teacher"/>
                <field name="is_student"/>
                <field name="municipality"/>
                <field name="teacher_state" optional="show"/>
                <field name="rating" optional="show"/>
                <button name="action_validate" string="Validate" type="object" icon="fa-check"
                        invisible="not is_teacher or teacher_state == 'validated'"/>
                <button name="action_reject" string="Reject" type="object" icon="fa-times"
                        invisible="not is_teacher or teacher_state != 'validated'"/>
            </list>
        </field>
    </record>

    <record id="view_lt_profile_search" model="ir.ui.view">
        <field name="name">lt.profile.search</field>
        <field name="model">lt.profile</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="municipality"/>
                <filter name="teachers" string="Teachers" domain="[('is_teacher','=',True)]"/>
                <filter name="students" string="Students" domain="[('is_student','=',True)]"/>
                <filter name="pending" string="Pending validation"
                        domain="[('is_teacher','=',True),('teacher_state','=','draft')]"/>
                <filter name="validated" string="Validated teachers"
                        domain="[('is_teacher','=',True),('teacher_state','=','validated')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Teacher Status" context="{'group_by': 'teacher_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_lt_profile" model="ir.actions.act_window">
        <field name="name">Profiles</field>
        <field name="res_model">lt.profile</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_pending': 1}</field>
    </record>
</odoo>
